[36.229442, "o", "5\r\n"]
[37.236079, "o", "\u001b[0;33m$ grep alias /etc/bash.bashrc\u001b[0m\r\n"]
[37.655887, "o", "alias ll='ls -la'\r\n"]
[38.663621, "o", "\u001b[0;33m$ ls /workspace/myapp\u001b[0m\r\n"]
[39.081041, "o", "README.md\r\n"]
[40.084931, "o", "\u001b[1;32mвң“ everything is back, anywhere on disk\u001b[0m\r\n"]
[43.09258, "o", "\r\n\u001b[1;36mв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ Scene 4 вҖ” branch & explore: try 3 fixes IN PARALLEL, keep the one that passes в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\u001b[0m\r\n"]
[44.132072, "o", "\u001b[0;37mTask: pick the operator that makes 'mul 3 4' equal 12 вҖ” try '+', '*', '-' in parallel.\u001b[0m\r\n"]
[45.135655, "o", "\u001b[0;37mEach candidate sleeps 3s simulating real build time, so the speedup is visible:\u001b[0m\r\n"]
[46.143371, "o", "\u001b[0;37msequential would take 9s; truly parallel вүҲ 3s.\u001b[0m\r\n"]
[47.149042, "o", "\r\n\u001b[0;33m$ agentenv tournament --base=good --keep --test='[ \"$(mul 3 4)\" = 12 ]' -- \\\u001b[0m\r\n\u001b[0;33m     'sleep 3; echo -e \"#!/bin/sh\\necho \\$((\\$1 + \\$2))\" > /usr/local/bin/mul && chmod +x /usr/local/bin/mul' \\\u001b[0m\r\n\u001b[0;33m     'sleep 3; echo -e \"#!/bin/sh\\necho \\$((\\$1 * \\$2))\" > /usr/local/bin/mul && chmod +x /usr/local/bin/mul' \\\u001b[0m\r\n\u001b[0;33m     'sleep 3; echo -e \"#!/bin/sh\\necho \\$((\\$1 - \\$2))\" > /usr/local/bin/mul && chmod +x /usr/local/bin/mul'\u001b[0m\r\n"]
[51.69339, "o", "base: f1144076368c9f61f993578f\r\n  branch A  вҶ’  7f38d7c7db7d19d860e65859  (exit 1)  [sleep 3; echo -e \"#!/bin/sh\\necho \\$((\\$1 + \\$2))вҖҰ]\r\n  branch B  вҶ’  765839298dda29bed6a4709c  (PASS)  [sleep 3; echo -e \"#!/bin/sh\\necho \\$((\\$1 * \\$2))вҖҰ]\r\n  branch C  вҶ’  f0c2e72648ab136a112319a9  (exit 1)  [sleep 3; echo -e \"#!/bin/sh\\necho \\$((\\$1 - \\$2))вҖҰ]\r\nwinner: branch B  (node 765839298dda29bed6a4709c)\r\nHEAD is now 765839298dda29bed6a4709c\r\n"]
[51.694516, "o", "\r\n\u001b[1;32mвҶ‘ 3 Г— 3s candidates, wall-clock 4s (sequential would be вүҘ9s) вҖ” truly parallel\u001b[0m\r\n"]
[54.696009, "o", "\r\n\u001b[1;36mв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ the resulting history в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\u001b[0m\r\n"]
[55.706381, "o", "в””в”Җ b1ddffabf3ae05b1eca4abe9  \"init from ubuntu\"\r\n   в””в”Җ f1144076368c9f61f993578f  \"set up: calc tool + bashrc alias + project\"\r\n      в”ңв”Җ fadcd9a7c66f576d71a7c6ba  \"wrecked\"\r\n      в”ңв”Җ f0c2e72648ab136a112319a9  \"tournament C: sleep 3; echo -e \\\"#!/bin/sh\\\\necho \\\\$((\\\\$1 - \\\\вҖҰ\"\r\n      в”ңв”Җ 765839298dda29bed6a4709c  \"tournament B: sleep 3; echo -e \\\"#!/bin/sh\\\\necho \\\\$((\\\\$1 * \\\\вҖҰ\"  <- HEAD\r\n      в””в”Җ 7f38d7c7db7d19d860e65859  \"tournament A: sleep 3; echo -e \\\"#!/bin/sh\\\\necho \\\\$((\\\\$1 + \\\\вҖҰ\"\r\n"]
[57.711526, "o", "\r\n\u001b[1;32mrewind any node вҖў branch & keep the best вҖў agent zero-changes вҖў self-hosted, unprivileged\u001b[0m\r\n"]
