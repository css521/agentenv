{
  // One-click Linux dev environment for VS Code / Cursor / GitHub Codespaces.
  // From the editor: "Reopen in Container" — you get a Linux Go toolchain with
  // libbtrfs-dev pre-installed, seccomp relaxed so agentenv's user-namespace
  // runner works, and the project source mounted as the workspace.
  "name": "agentenv-dev",
  // Image-version 2.x is where MS publishes Go 1.25+ (the older 1-1.xx
  // line tops out at Go 1.24, which fails our go.mod's `go 1.26` directive).
  "image": "mcr.microsoft.com/devcontainers/go:2.1-1.26",

  // The agentenv runner clones into a fresh user namespace; the dev container's
  // default seccomp profile blocks that. Unconfining it inside the dev container
  // is fine — the container itself is the boundary.
  "runArgs": [
    "--security-opt=seccomp=unconfined",
    "--security-opt=apparmor=unconfined"
  ],

  // No `features` block: the MS Go devcontainer image already ships the
  // vscode user, sudo, git, curl, zsh, oh-my-zsh, and everything else
  // common-utils would have installed.
  //
  // postcreate.sh installs libbtrfs-dev + make (so `-tags btrfs` builds
  // work), and — if AGENTENV_CN_MIRROR=1 was set on the host — swaps
  // /etc/apt sources to mirrors.aliyun.com so apt-get doesn't stall
  // behind deb.debian.org from mainland China. The env var flows in via
  // containerEnv below; OSS users outside China leave it unset and the
  // mirror swap is a no-op.
  "postCreateCommand": ".devcontainer/postcreate.sh",
  "containerEnv": {
    "AGENTENV_CN_MIRROR": "${localEnv:AGENTENV_CN_MIRROR}"
  },
  // Show the Makefile target list every time the container is attached, so a new
  // contributor immediately sees what they can do (build / test / verify / demo).
  "postAttachCommand": "make help",

  "remoteUser": "vscode",

  "customizations": {
    "vscode": {
      "settings": {
        "go.testFlags": ["-race"],
        "gopls": { "build.buildFlags": ["-tags=btrfs"] }
      },
      "extensions": [
        "golang.go"
      ]
    }
  }
}
